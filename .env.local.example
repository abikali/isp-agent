# Database
DATABASE_URL="YOUR_DATABASE_CONNECTION_STRING"
# ... if you use Supabase
DIRECT_URL=""

# Site url
VITE_SITE_URL="http://localhost:3000"

# Authentication
BETTER_AUTH_SECRET="A_RANDOM_SECRET_STRING"
# ... for Github
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"
# ... for Google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Mails
# ... with nodemailer
MAIL_HOST=""
MAIL_PORT=""
MAIL_USER=""
MAIL_PASS=""
# ... with Plunk
PLUNK_API_KEY=""
# ... with Resend
RESEND_API_KEY=""
# ... with Postmark
POSTMARK_SERVER_TOKEN=""
# ... with Mailgun
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""

# Payments
# ... with Lemonsqueezy
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_STORE_ID=""
# ... with Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# ... with Creem
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
# ... with Polar
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
# ... with DodoPayments
DODO_PAYMENTS_API_KEY=""

# Product price ids
VITE_PRICE_ID_PRO_MONTHLY="asdf"
VITE_PRICE_ID_PRO_YEARLY="asdf"
VITE_PRICE_ID_LIFETIME="asdf"

# Analytics
# ... for Pirsch
VITE_PIRSCH_CODE=""
# ... for Plausible
VITE_PLAUSIBLE_URL=""
# ... for Mixpanel
VITE_MIXPANEL_TOKEN=""
# ... for Google Analytics
VITE_GOOGLE_ANALYTICS_ID=""

# Error Tracking & Performance Monitoring (Sentry)
SENTRY_DSN=""              # Server-side DSN
VITE_SENTRY_DSN=""         # Client-side DSN (same value as SENTRY_DSN)

# Storage (S3-compatible: AWS S3, Cloudflare R2, MinIO, etc.)
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
S3_REGION="auto"
AVATARS_BUCKET_NAME="avatars"
S3_PUBLIC_URL=""  # Optional: Public URL for serving images directly (e.g., R2 public URL)

# Redis (for job queues, rate limiting, caching)
REDIS_URL="redis://localhost:6379"

# Webhook token signing (generate with: openssl rand -base64 32)
WEBHOOK_SECRET=""

# Integrations (Nango - supports self-hosted)
# For Nango Cloud: Get keys from https://app.nango.dev/environment-settings
# For self-hosted: Get keys from your Nango dashboard
NANGO_SECRET_KEY=""
VITE_NANGO_PUBLIC_KEY=""
# Self-hosted Nango URL (leave empty for Nango Cloud)
NANGO_HOST=""
VITE_NANGO_HOST=""
