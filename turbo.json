{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": ["**/.env.*local"],
	"globalEnv": [
		"VITE_SITE_URL",
		"SITE_URL",
		"AVATARS_BUCKET_NAME",
		"VITE_SENTRY_DSN",
		"VITE_NANGO_PUBLIC_KEY",
		"VITE_NANGO_HOST",
		"NODE_ENV"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^generate", "^build"],
			"outputs": ["dist/**", ".output/**"]
		},
		"type-check": {},
		"clean": {
			"cache": false
		},
		"generate": {
			"outputs": ["prisma/generated/**"]
		},
		"dev": {
			"cache": false,
			"dependsOn": ["^generate"],
			"persistent": true,
			"passThroughEnv": ["*"]
		},
		"export": {
			"outputs": ["out/**"]
		},
		"start": {
			"cache": false,
			"dependsOn": ["^generate", "^build"],
			"persistent": true,
			"passThroughEnv": ["*"]
		},
		"worker": {
			"cache": false,
			"dependsOn": ["^generate"],
			"persistent": true,
			"passThroughEnv": ["*"]
		}
	}
}
