# ============================================================
# LibanCom Production Environment Configuration
# ============================================================
# Copy this file to .env.production and fill in the values
# Generate secrets with: openssl rand -base64 32
# ============================================================

# ========== Database ==========
POSTGRES_USER=postgres
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_DB=libancom

# ========== Authentication ==========
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ========== URLs ==========
# For local testing (without nginx/SSL):
#   VITE_SITE_URL=http://localhost:3000
#   SITE_URL=http://localhost:3000
#
# For production with nginx + Cloudflare, use your actual domains:
VITE_SITE_URL=https://libancom.co
SITE_URL=https://libancom.co

# ========== Storage (Cloudflare R2 / AWS S3) ==========
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
AVATARS_BUCKET_NAME=avatars
# Optional: Public URL for R2 (if using public bucket)
S3_PUBLIC_URL=

# ========== Email ==========
MAIL_FROM=noreply@libancom.co
# Resend API key for transactional emails
RESEND_API_KEY=

# ========== Payments (Stripe) ==========
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ========== Price IDs (optional) ==========
VITE_PRICE_ID_PRO_MONTHLY=
VITE_PRICE_ID_PRO_YEARLY=
VITE_PRICE_ID_LIFETIME=
