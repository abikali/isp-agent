# ============================================================
# LibanCom Production Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# For VitoDeploy: paste these into Site > Application > .env
# Generate secrets with: openssl rand -base64 32
# ============================================================

# ========== Core ==========
NODE_ENV=production
PORT=3000

# ========== Database ==========
# Full connection string (used by Prisma and the app)
DATABASE_URL="postgresql://libancom:PASSWORD@localhost:5432/libancom"

# Docker Compose only (ignored in bare-metal deploys):
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=libancom

# ========== Redis ==========
REDIS_URL="redis://localhost:6379"

# ========== Authentication ==========
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Must match your public URL (used by Better Auth for callbacks)
BETTER_AUTH_URL="https://libancom.abiroot.dev"

# ========== URLs ==========
# VITE_* vars are baked into the client bundle at build time
VITE_SITE_URL="https://libancom.abiroot.dev"
SITE_URL="https://libancom.abiroot.dev"

# ========== AI ==========
# Encryption key for storing AI channel API tokens in DB
# Generate with: openssl rand -hex 32 (must be 64 hex chars)
AI_CHANNEL_ENCRYPTION_KEY=

# AI Providers (at least one required for AI agents)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ========== Webhooks ==========
# Token signing secret. Generate with: openssl rand -base64 32
WEBHOOK_SECRET=

# ========== Storage (Cloudflare R2 / AWS S3) ==========
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
AVATARS_BUCKET_NAME=avatars
# Optional: Public URL for R2 (if using public bucket)
S3_PUBLIC_URL=

# ========== Email ==========
MAIL_FROM=noreply@libancom.abiroot.dev
# Resend API key for transactional emails
RESEND_API_KEY=

# ========== Social Auth (optional) ==========
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ========== Payments (Stripe, optional) ==========
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ========== Price IDs (optional) ==========
PRICE_ID_PRO_MONTHLY=
PRICE_ID_PRO_YEARLY=
PRICE_ID_LIFETIME=

# ========== Error Tracking (optional) ==========
SENTRY_DSN=
VITE_SENTRY_DSN=

# ========== Integrations (Nango, optional) ==========
NANGO_SECRET_KEY=
VITE_NANGO_PUBLIC_KEY=
# Self-hosted Nango URL (leave empty for Nango Cloud)
NANGO_HOST=
VITE_NANGO_HOST=
