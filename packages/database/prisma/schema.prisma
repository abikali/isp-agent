generator client {
  provider        = "prisma-client"
  output          = "./generated"
  engineType      = "client"
  previewFeatures = ["strictUndefinedChecks"]
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  expiresAt             DateTime?
  password              String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model AccountLockout {
  id             String    @id @default(cuid())
  userId         String    @unique
  lockedAt       DateTime  @default(now())
  unlocksAt      DateTime
  failedAttempts Int       @default(0)
  reason         String?
  unlockedAt     DateTime?
  unlockedBy     String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([unlocksAt])
  @@map("account_lockout")
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique
  keyPrefix      String
  organizationId String
  createdById    String
  permissions    String[]
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([keyHash])
  @@index([organizationId])
  @@map("api_key")
}

model AuditLog {
  id             String        @id @default(cuid())
  userId         String?
  organizationId String?
  action         String
  resourceType   String
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([organizationId])
  @@index([resourceType])
  @@index([userId])
  @@map("audit_log")
}

model BulkOperation {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  type           String // import_csv, duplicate_template, bulk_edit, bulk_delete, bulk_publish, bulk_export, bulk_duplicate, bulk_assign
  status         String       @default("pending") // pending, processing, completed, failed, cancelled
  totalItems     Int
  processedItems Int          @default(0)
  successCount   Int          @default(0)
  errorCount     Int          @default(0)
  errors         Json?
  input          Json?
  result         Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("bulk_operation")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  percentage  Int      @default(100)
  targetUsers String[] @default([])
  targetOrgs  String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@map("feature_flag")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([inviterId])
  @@index([expiresAt])
  @@map("invitation")
}

model KnownDevice {
  id                String   @id @default(cuid())
  userId            String
  deviceFingerprint String
  deviceName        String?
  userAgent         String?
  ipAddress         String?
  lastSeenAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@index([userId])
  @@map("known_device")
}

model LoginAttempt {
  id            String   @id @default(cuid())
  userId        String?
  email         String
  ipAddress     String?
  userAgent     String?
  success       Boolean  @default(false)
  failureReason String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([ipAddress])
  @@index([userId])
  @@map("login_attempt")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("member")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  category  String?  // "leads" | "team" | "analytics" | "security"
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, read])
  @@index([userId, category])
  @@map("notification")
}

model NotificationPreference {
  id             String  @id @default(cuid())
  userId         String  @unique

  // Per-category in-app toggles
  leadsInApp     Boolean @default(true)
  teamInApp      Boolean @default(true)
  analyticsInApp Boolean @default(true)
  securityInApp  Boolean @default(true)

  // Per-category email toggles
  leadsEmail     Boolean @default(true)
  teamEmail      Boolean @default(true)
  analyticsEmail Boolean @default(false)
  securityEmail  Boolean @default(true)

  // Monitoring
  monitoringInApp Boolean @default(true)
  monitoringEmail Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preference")
}

model Organization {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String?            @unique
  logo                 String?
  createdAt            DateTime
  metadata             Json?
  paymentsCustomerId   String?
  aiDefaultPersona     String?            @db.Text
  aiDefaultGreeting    String?
  aiProfileLimit       Int?               // Max credits per profile per month (null = no limit)
  aiAllowedModels      String[]           @default([]) // LLM models whitelisted by org admin
  aiAgents             AiAgent[]
  aiCapturedLeads      AiCapturedLead[]
  apiKeys              ApiKey[]
  auditLogs            AuditLog[]
  bulkOperations       BulkOperation[]
  integrationConnections IntegrationConnection[]
  invitations          Invitation[]
  members              Member[]
  roles                OrganizationRole[]
  purchases            Purchase[]
  usageQuotas          UsageQuota[]
  watchers             Watcher[]
  webhooks             Webhook[]
  customers            Customer[]
  employees            Employee[]
  servicePlans         ServicePlan[]
  stations             Station[]
  tasks                Task[]

  @@map("organization")
}

model OrganizationRole {
  id             String       @id @default(cuid())
  organizationId String
  role           String
  permission     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role])
  @@map("organization_role")
}

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkey")
}

model Purchase {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  type           PurchaseType
  customerId     String
  subscriptionId String?       @unique
  productId      String
  status         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([subscriptionId])
  @@index([customerId])
  @@map("purchase")
}

model Session {
  id                   String   @id @default(cuid())
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  userId               String
  impersonatedBy       String?
  activeOrganizationId String?
  token                String   @unique
  createdAt            DateTime
  updatedAt            DateTime
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor")
}

model UsageQuota {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  quotaType      String
  used           Int           @default(0)
  limit          Int
  resetAt        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, quotaType])
  @@unique([userId, quotaType])
  @@index([organizationId])
  @@index([quotaType])
  @@index([userId])
  @@map("usage_quota")
}

model User {
  id                  String          @id @default(cuid())
  name                String
  email               String          @unique
  emailVerified       Boolean
  image               String?
  createdAt           DateTime
  updatedAt           DateTime
  username            String?         @unique
  role                String?
  banned              Boolean?
  banReason           String?
  banExpires          DateTime?
  onboardingComplete  Boolean         @default(false)
  paymentsCustomerId  String?
  locale              String?
  displayUsername     String?
  twoFactorEnabled    Boolean?
  deletionScheduledAt DateTime?
  deletionReason      String?
  accounts            Account[]
  accountLockout      AccountLockout?
  aiAgentsCreated     AiAgent[]      @relation("aiAgentCreator")
  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  bulkOperations      BulkOperation[]
  integrationConnections IntegrationConnection[]
  invitations         Invitation[]
  knownDevices        KnownDevice[]
  loginAttempts       LoginAttempt[]
  members             Member[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  passkeys                Passkey[]
  purchases           Purchase[]
  sessions            Session[]
  twoFactors          TwoFactor[]
  usageQuotas         UsageQuota[]
  watchersCreated     Watcher[]          @relation("watcherCreator")
  tasksCreated        Task[]             @relation("taskCreator")

  @@map("user")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Webhook {
  id             String            @id @default(cuid())
  organizationId String
  url            String
  secret         String
  events         String[]
  enabled        Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries     WebhookDelivery[]

  @@index([organizationId])
  @@map("webhook")
}

model WebhookDelivery {
  id          String    @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  response    String?   @db.Text
  attempts    Int       @default(0)
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  webhook     Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([webhookId])
  @@map("webhook_delivery")
}

// ============================================================================
// INTEGRATION MODELS (Third-party integrations via Nango)
// ============================================================================

model IntegrationConnection {
  id                String   @id @default(cuid())
  organizationId    String
  createdById       String

  // Nango identifiers
  providerConfigKey String   // "hubspot", "salesforce", "slack"
  connectionId      String   // Nango's unique connection ID

  // Display
  name              String?  // User-friendly name
  providerName      String   // "HubSpot", "Salesforce"

  // Sync configuration (user-configurable)
  syncMode          String   @default("manual") // "manual" | "auto"
  autoSyncEvents    String[] @default([])       // ["contact.created", "contact.updated"]

  // Status
  status            String   @default("connected") // connected, error, disconnected
  lastSyncAt        DateTime?
  lastError         String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization      Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy         User                    @relation(fields: [createdById], references: [id], onDelete: Cascade)
  syncOperations    ContactSyncOperation[]

  @@unique([organizationId, providerConfigKey])
  @@index([organizationId])
  @@index([createdById])
  @@index([status])
  @@map("integration_connection")
}

model ContactSyncOperation {
  id            String   @id @default(cuid())
  connectionId  String

  // Operation details
  type          String   // "push_single", "push_bulk", "sync_all"
  status        String   @default("pending") // pending, processing, completed, failed
  trigger       String?  // "manual", "contact.created", "contact.updated"

  // Counts
  totalContacts Int
  successCount  Int      @default(0)
  errorCount    Int      @default(0)

  // Results
  errors        Json?    // Array of {contactId, error} objects
  result        Json?    // Provider response data

  // Timing
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  connection    IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
  @@map("contact_sync_operation")
}

// ============================================================================
// AI AGENT MODELS (Chat agents for WhatsApp/Telegram)
// ============================================================================

model AiAgent {
  id               String           @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  systemPrompt     String           @db.Text
  greetingMessage  String?
  model            String           @default("gpt-4o-mini")
  knowledgeBase    String?          @db.Text
  enabled             Boolean          @default(true)
  maintenanceMode     Boolean          @default(false)
  maintenanceMessage  String?          @db.Text
  maxHistoryLength Int              @default(20)
  temperature      Float            @default(0.3)
  enabledTools     String[]         @default([])
  webChatEnabled   Boolean          @default(false)
  webChatToken     String?          @unique
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User                  @relation("aiAgentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  channels       AiAgentChannel[]
  conversations  AiConversation[]
  toolConfigs    AiAgentToolConfig[]
  capturedLeads  AiCapturedLead[]

  @@index([organizationId])
  @@map("ai_agent")
}

model AiAgentChannel {
  id                String    @id @default(cuid())
  agentId           String
  provider          String    // "whatsapp" | "telegram"
  name              String
  webhookToken      String    @unique
  webhookSecret     String?   // For Telegram secret_token verification
  encryptedApiToken String    @db.Text
  providerMetadata  Json?
  enabled           Boolean   @default(true)
  lastActivityAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  agent         AiAgent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversations AiConversation[]

  @@index([agentId])
  @@map("ai_agent_channel")
}

model AiConversation {
  id                 String    @id @default(cuid())
  agentId            String
  channelId          String?
  externalChatId     String
  contactName        String?
  contactId          String?
  status             String    @default("active")
  pinned             Boolean   @default(false)
  messageCount       Int       @default(0)
  lastMessageAt      DateTime?
  verifiedCustomerId String?
  pinAttempts        Int       @default(0)
  pinLockedUntil     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  agent            AiAgent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channel          AiAgentChannel?  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  verifiedCustomer Customer?        @relation(fields: [verifiedCustomerId], references: [id], onDelete: SetNull)
  messages         AiMessage[]
  capturedLeads    AiCapturedLead[]

  @@unique([channelId, externalChatId])
  @@index([agentId])
  @@index([agentId, externalChatId])
  @@index([channelId])
  @@index([lastMessageAt])
  @@map("ai_conversation")
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String   @db.Text
  externalMsgId  String?
  tokenCount     Int?
  latencyMs      Int?
  error          String?
  toolCalls      Json?    // Array of {toolName, args, result}
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_message")
}

model AiAgentToolConfig {
  id        String   @id @default(cuid())
  agentId   String
  toolId    String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, toolId])
  @@index([agentId])
  @@map("ai_agent_tool_config")
}

model AiCapturedLead {
  id             String   @id @default(cuid())
  organizationId String
  agentId        String
  conversationId String
  externalChatId String
  name           String
  email          String?
  phone          String?
  company        String?
  title          String?
  notes          String?  @db.Text
  source         String   @default("ai_agent")
  exportedToCrm  Boolean  @default(false)
  crmExportId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        AiAgent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agentId])
  @@index([conversationId])
  @@map("ai_captured_lead")
}

// ============================================================================
// WATCHER MODELS (Infrastructure monitoring)
// ============================================================================

model Watcher {
  id               String    @id @default(cuid())
  organizationId   String
  createdById      String
  name             String
  type             String    // "ping" | "http" | "port" | "dns"
  target           String    // hostname, URL, or IP
  config           Json?     // type-specific: { port, expectedStatus, method, recordType, etc. }
  intervalSeconds  Int       // 60, 300, 900, 1800, 3600
  enabled          Boolean   @default(true)
  status           String    @default("unknown") // "up" | "down" | "unknown"
  lastCheckedAt    DateTime?
  lastStatusChange DateTime?
  nextRunAt        DateTime  @default(now())
  notifiedDownAt     DateTime? // throttle: null = not notified yet for current incident
  notificationConfig Json?
  lastReminderAt     DateTime?
  consecutiveFails Int       @default(0)
  consecutiveOk    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User               @relation("watcherCreator", fields: [createdById], references: [id], onDelete: Cascade)
  executions   WatcherExecution[]

  @@index([organizationId])
  @@index([enabled, nextRunAt])
  @@map("watcher")
}

model WatcherExecution {
  id        String   @id @default(cuid())
  watcherId String
  status    String   // "up" | "down"
  latencyMs Int?
  message   String?
  metadata  Json?
  createdAt DateTime @default(now())

  watcher Watcher @relation(fields: [watcherId], references: [id], onDelete: Cascade)

  @@index([watcherId, createdAt])
  @@map("watcher_execution")
}

enum PurchaseType {
  SUBSCRIPTION
  ONE_TIME
}

// ============================================================================
// CUSTOMER MANAGEMENT MODELS (ISP subscriber management)
// ============================================================================

enum CustomerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum ConnectionType {
  FIBER
  WIRELESS
  DSL
  CABLE
  ETHERNET
}

enum StationStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
}

model ServicePlan {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  downloadSpeed  Int // Mbps
  uploadSpeed    Int // Mbps
  monthlyPrice   Float
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customers    Customer[]

  @@index([organizationId])
  @@map("service_plan")
}

model Station {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  address        String?
  latitude       Float?
  longitude      Float?
  status         StationStatus @default(ACTIVE)
  capacity       Int?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customers    Customer[]
  employees    EmployeeStation[]
  tasks        Task[]

  @@index([organizationId])
  @@map("station")
}

model Customer {
  id             String          @id @default(cuid())
  organizationId String
  accountNumber  String
  fullName       String
  email          String?
  phone          String?
  address        String?
  username       String?
  planId         String?
  stationId      String?
  status         CustomerStatus  @default(ACTIVE)
  connectionType ConnectionType?
  ipAddress      String?
  macAddress     String?
  monthlyRate    Float?
  billingDay     Int?
  balance        Float           @default(0)
  notes          String?         @db.Text
  pin            String?
  pinHash        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan          ServicePlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  station       Station?         @relation(fields: [stationId], references: [id], onDelete: SetNull)

  tasks         Task[]
  conversations AiConversation[]

  @@unique([organizationId, accountNumber])
  @@index([organizationId])
  @@index([planId])
  @@index([stationId])
  @@index([status])
  @@index([organizationId, fullName])
  @@map("customer")
}

// ============================================================================
// EMPLOYEE & TASK MANAGEMENT MODELS
// ============================================================================

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum EmployeeDepartment {
  TECHNICAL
  CUSTOMER_SERVICE
  BILLING
  MANAGEMENT
  FIELD_OPS
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskCategory {
  INSTALLATION
  MAINTENANCE
  REPAIR
  SUPPORT
  BILLING
  GENERAL
}

model Employee {
  id             String             @id @default(cuid())
  organizationId String
  employeeNumber String
  name           String
  email          String?
  phone          String?
  position       String?
  department     EmployeeDepartment?
  hireDate       DateTime?
  status         EmployeeStatus     @default(ACTIVE)
  notes          String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stations     EmployeeStation[]
  taskAssignments TaskAssignment[]

  @@unique([organizationId, employeeNumber])
  @@index([organizationId])
  @@index([status])
  @@index([organizationId, name])
  @@map("employee")
}

model EmployeeStation {
  id         String   @id @default(cuid())
  employeeId String
  stationId  String
  assignedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  station  Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([employeeId, stationId])
  @@index([employeeId])
  @@index([stationId])
  @@map("employee_station")
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  description    String?      @db.Text
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus   @default(OPEN)
  category       TaskCategory @default(GENERAL)
  dueDate        DateTime?
  completedAt    DateTime?
  notes          String?      @db.Text
  createdById    String
  customerId     String?
  stationId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User             @relation("taskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  customer     Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  station      Station?         @relation(fields: [stationId], references: [id], onDelete: SetNull)
  assignments  TaskAssignment[]

  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([customerId])
  @@index([stationId])
  @@index([dueDate])
  @@map("task")
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  employeeId String
  assignedAt DateTime @default(now())

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([taskId, employeeId])
  @@index([taskId])
  @@index([employeeId])
  @@map("task_assignment")
}

