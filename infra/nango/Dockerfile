FROM nangohq/nango:hosted

# Self-hosted Nango for LibanCom integrations
#
# Required environment variables:
# - NANGO_SERVER_URL: Public URL of this service
# - NANGO_DATABASE_URL: PostgreSQL connection string
# - NANGO_REDIS_URL: Redis connection string (optional but recommended)
# - NANGO_ENCRYPTION_KEY: 256-bit base64 key for encrypting tokens
# - NANGO_DASHBOARD_USERNAME: Admin dashboard username
# - NANGO_DASHBOARD_PASSWORD: Admin dashboard password
#
# The base image handles everything else automatically.
